{
  "info": {
    "name": "Jaipur Tourism Portal API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Website (Public)",
      "item": [
        {
          "name": "Inquiries",
          "item": [
            {
              "name": "Create Inquiry",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"customerName\": \"John Doe\",\n  \"contact\": \"john@example.com\",\n  \"destinationInterest\": \"Amber Fort\",\n  \"travelDates\": \"2026-10-15T00:00:00.000Z\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/website/inquiries",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "website",
                    "inquiries"
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "Testimonials",
          "item": [
            {
              "name": "Submit Testimonial",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"rating\": 5,\n  \"description\": \"Great trip to Jaipur!\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/website/testimonials",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "website",
                    "testimonials"
                  ]
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin (Protected)",
      "item": [
        {
          "name": "Auth & Profile",
          "item": [
            {
              "name": "Admin Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const response = pm.response.json();",
                      "if(response.data && response.data.token) {",
                      "    pm.collectionVariables.set(\"jwt_token\", response.data.token);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"mohit@mailinator.com\",\n  \"password\": \"123123123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/auth/login",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "admin",
                    "auth",
                    "login"
                  ]
                }
              }
            },
            {
              "name": "Forgot Password",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"mohit@mailinator.com\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/auth/forgotPassword",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "admin",
                    "auth",
                    "forgotPassword"
                  ]
                }
              }
            },
            {
              "name": "Reset Password",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"password\": \"newpassword123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/auth/resetPassword/:token",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "admin",
                    "auth",
                    "resetPassword",
                    ":token"
                  ],
                  "variable": [
                    {
                      "key": "token",
                      "value": "paste_reset_token_here"
                    }
                  ]
                }
              }
            },
            {
              "name": "Get Profile",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/auth/profile",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "admin",
                    "auth",
                    "profile"
                  ]
                }
              }
            },
            {
              "name": "Update Profile",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Super Admin Updated\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/auth/profile",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "admin",
                    "auth",
                    "profile"
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "Inquiries",
          "item": [
            {
              "name": "Get All Inquiries (Paginated & Filtered)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/inquiries?page=1&limit=10&sortBy=createdAt&sortOrder=desc",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "admin",
                    "inquiries"
                  ],
                  "query": [
                    {
                      "key": "page",
                      "value": "1"
                    },
                    {
                      "key": "limit",
                      "value": "10"
                    },
                    {
                      "key": "sortBy",
                      "value": "createdAt"
                    },
                    {
                      "key": "sortOrder",
                      "value": "desc"
                    }
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "CMS - Testimonials",
          "item": [
            {
              "name": "Get All Testimonials",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/testimonials",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "admin",
                    "testimonials"
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "CMS - Email Templates",
          "item": [
            {
              "name": "Get All Email Templates",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/email-templates",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "admin",
                    "email-templates"
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const url = pm.request.url.toString();",
          "if (url.includes('/admin') && !url.includes('/login') && !url.includes('/resetPassword') && !url.includes('/forgotPassword')) {",
          "    const token = pm.collectionVariables.get('jwt_token');",
          "    if (!token) console.warn('No JWT token found! Please login first.');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ]
}