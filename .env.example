PORT=3000
NODE_ENV=development

# Database
# Use exact DB name casing (macOS MongoDB is case-sensitive): tripPlanner
MONGO_URI=mongodb://127.0.0.1:27017/tripPlanner

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=10d

# CORS & Web
CORS_WHITELIST=http://localhost:3000,http://localhost:5173
WEB_ORIGIN=http://localhost:5173
BASE_URL=http://localhost:3000

# SMTP
EMAIL_FROM=no-reply@tripplanner.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@tripplanner.com
ADMIN_EMAIL=admin@example.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=100

# Uploads (local fallback when AWS_* unset; S3 prefix when configured)
PROFILE_IMAGE_MAX_SIZE_MB=5
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads2/

# AWS S3 (private bucket + presigned URLs)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=
AWS_PRESIGNED_URL_EXPIRES_SECONDS=3600
